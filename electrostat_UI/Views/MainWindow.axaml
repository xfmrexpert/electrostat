<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:electrostat_UI.ViewModels"
        xmlns:cvm="using:electrostat_UI.ViewModels.Components"
        xmlns:views="using:electrostat_UI.Views"
        xmlns:cviews="using:electrostat_UI.Views.Components"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="750"
        x:Class="electrostat_UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding WindowTitle}">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.DataTemplates>
        <!-- Auto-pick the right editor view for whatever SelectedComponent is. -->
        <DataTemplate DataType="cvm:DomainViewModel">
            <cviews:DomainEditorView/>
        </DataTemplate>
        <DataTemplate DataType="cvm:WindingViewModel">
            <cviews:WindingEditorView/>
        </DataTemplate>
        <DataTemplate DataType="cvm:PressboardViewModel">
            <cviews:PressboardEditorView/>
        </DataTemplate>
        <DataTemplate DataType="cvm:AngleRingViewModel">
            <cviews:AngleRingEditorView/>
        </DataTemplate>
        <DataTemplate DataType="cvm:StaticRingViewModel">
            <cviews:StaticRingEditorView/>
        </DataTemplate>
        <DataTemplate DataType="cvm:CutViewModel">
            <cviews:CutEditorView/>
        </DataTemplate>
        <DataTemplate DataType="vm:VoltageScenarioViewModel">
            <StackPanel Spacing="4">
                <TextBlock Text="Voltage Scenario" FontWeight="SemiBold"/>
                <Grid ColumnDefinitions="Auto,*" RowSpacing="2" ColumnSpacing="6">
                    <TextBlock Grid.Column="0" Text="Name" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=LostFocus}"/>
                </Grid>
                <TextBlock Text="Winding voltages (V)" FontWeight="SemiBold" Margin="0,6,0,0"/>
                <ItemsControl ItemsSource="{Binding Cells}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ScenarioVoltageCell">
                            <Grid ColumnDefinitions="Auto,*" RowSpacing="2" ColumnSpacing="6" Margin="0,1">
                                <TextBlock Grid.Column="0" Text="{Binding WindingName}"
                                           VerticalAlignment="Center" MinWidth="70"/>
                                <NumericUpDown Grid.Column="1" Value="{Binding Voltage}"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock FontStyle="Italic" FontSize="11" Foreground="Gray" TextWrapping="Wrap"
                           Text="Nested static rings inherit their parent winding's voltage."/>
            </StackPanel>
        </DataTemplate>
    </Window.DataTemplates>

    <Grid RowDefinitions="Auto,*,Auto">
        <Menu Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem Header="_New" Command="{Binding NewCommand}" HotKey="Ctrl+N" InputGesture="Ctrl+N"/>
                <MenuItem Header="_Open..." Command="{Binding OpenCommand}" HotKey="Ctrl+O" InputGesture="Ctrl+O"/>
                <Separator/>
                <MenuItem Header="_Save" Command="{Binding SaveCommand}" HotKey="Ctrl+S" InputGesture="Ctrl+S"/>
                <MenuItem Header="Save _As..." Command="{Binding SaveAsCommand}" HotKey="Ctrl+Shift+S" InputGesture="Ctrl+Shift+S"/>
                <Separator/>
                <MenuItem Header="_Examples"
                          ItemsSource="{Binding Examples}">
                    <MenuItem.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                    </MenuItem.ItemTemplate>
                    <MenuItem.ItemContainerTheme>
                        <ControlTheme TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                            <Setter Property="Command"
                                    Value="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OpenExampleCommand}"/>
                            <Setter Property="CommandParameter" Value="{Binding}"/>
                        </ControlTheme>
                    </MenuItem.ItemContainerTheme>
                </MenuItem>
                <Separator/>
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="Add _Winding" Command="{Binding AddWindingCommand}"/>
                <MenuItem Header="Add _Pressboard" Command="{Binding AddPressboardCommand}"/>
                <MenuItem Header="Add _Angle Ring" Command="{Binding AddAngleRingCommand}"/>
                <MenuItem Header="Add _Static Ring" Command="{Binding AddStaticRingCommand}"/>
                <MenuItem Header="Add Sc_enario" Command="{Binding AddScenarioCommand}"/>
                <MenuItem Header="Add _Cut" Command="{Binding AddCutCommand}"/>
                <Separator/>
                <MenuItem Header="_Remove Selected" Command="{Binding RemoveSelectedCommand}"/>
            </MenuItem>
            <MenuItem Header="_Run">
                <MenuItem Header="Solve _Cut" Command="{Binding SolveCutCommand}"/>
                <MenuItem Header="Solve _All Cuts" Command="{Binding SolveAllCutsCommand}"/>
                <Separator/>
                <MenuItem Header="Adaptive _Mesh Refinement"
                          ToggleType="CheckBox"
                          IsChecked="{Binding UseAdaptiveRefinement, Mode=TwoWay}"/>
            </MenuItem>
        </Menu>

        <TabControl Grid.Row="1" SelectedIndex="{Binding ActiveTabIndex, Mode=TwoWay}">
            <TabItem Header="Design">
                <Grid ColumnDefinitions="260,4,280,*">
                    <Grid Grid.Column="0" Margin="8" RowDefinitions="Auto,*">
                        <TextBlock Grid.Row="0" Text="Case" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TreeView Grid.Row="1"
                                  ItemsSource="{Binding CaseTree}"
                                  SelectedItem="{Binding SelectedTreeNode, Mode=TwoWay}">
                            <TreeView.Styles>
                                <!-- Bind each container's expansion to the node so it survives rebuilds. -->
                                <Style Selector="TreeViewItem" x:DataType="vm:CaseTreeNode">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                </Style>
                            </TreeView.Styles>
                            <TreeView.ItemTemplate>
                                <TreeDataTemplate ItemsSource="{Binding Children}"
                                                  x:DataType="vm:CaseTreeNode">
                                    <TextBlock Text="{Binding Name}"/>
                                </TreeDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </Grid>

                    <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                                  Background="Transparent"/>

                    <Grid Grid.Column="2" Margin="8" RowDefinitions="Auto,*,Auto">
                        <TextBlock Grid.Row="0" Text="Details" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" Padding="8">
                            <ScrollViewer>
                                <ContentControl Content="{Binding SelectedComponent}"/>
                            </ScrollViewer>
                        </Border>

                        <ProgressBar Grid.Row="2" IsIndeterminate="True"
                                     IsVisible="{Binding IsSolving}"
                                     Height="6" Margin="0,6,0,0"/>
                    </Grid>

                    <Border Grid.Column="3" Margin="8"
                            BorderBrush="Gray" BorderThickness="1">
                        <views:GeometryView Geometry="{Binding CurrentGeometry}"
                                            HighlightedSurfaces="{Binding HighlightedSurfaces}"
                                            SurfaceCategories="{Binding SurfaceCategories}"/>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Results">
                <views:ResultsWorkspaceView DataContext="{Binding Results}"/>
            </TabItem>
        </TabControl>

        <TextBlock Grid.Row="2"
                   Margin="12,4"
                   Text="{Binding StatusMessage}"/>
    </Grid>

</Window>
