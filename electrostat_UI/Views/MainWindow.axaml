<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:electrostat_UI.ViewModels"
        xmlns:cvm="using:electrostat_UI.ViewModels.Components"
        xmlns:views="using:electrostat_UI.Views"
        xmlns:cviews="using:electrostat_UI.Views.Components"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="750"
        x:Class="electrostat_UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="electrostat_UI">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.DataTemplates>
        <!-- Auto-pick the right editor view for whatever SelectedComponent is. -->
        <DataTemplate DataType="cvm:DomainViewModel">
            <cviews:DomainEditorView/>
        </DataTemplate>
        <DataTemplate DataType="cvm:WindingViewModel">
            <cviews:WindingEditorView/>
        </DataTemplate>
        <DataTemplate DataType="cvm:PressboardViewModel">
            <cviews:PressboardEditorView/>
        </DataTemplate>
        <DataTemplate DataType="cvm:AngleRingViewModel">
            <cviews:AngleRingEditorView/>
        </DataTemplate>
        <DataTemplate DataType="cvm:StaticRingViewModel">
            <cviews:StaticRingEditorView/>
        </DataTemplate>
        <DataTemplate DataType="cvm:CutViewModel">
            <cviews:CutEditorView/>
        </DataTemplate>
        <DataTemplate DataType="vm:VoltageScenarioViewModel">
            <StackPanel Spacing="4">
                <TextBlock Text="Voltage Scenario" FontWeight="SemiBold"/>
                <Grid ColumnDefinitions="Auto,*" RowSpacing="2" ColumnSpacing="6">
                    <TextBlock Grid.Column="0" Text="Name" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=LostFocus}"/>
                </Grid>
                <TextBlock Text="Winding voltages (V)" FontWeight="SemiBold" Margin="0,6,0,0"/>
                <ItemsControl ItemsSource="{Binding Cells}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ScenarioVoltageCell">
                            <Grid ColumnDefinitions="Auto,*" RowSpacing="2" ColumnSpacing="6" Margin="0,1">
                                <TextBlock Grid.Column="0" Text="{Binding WindingName}"
                                           VerticalAlignment="Center" MinWidth="70"/>
                                <NumericUpDown Grid.Column="1" Value="{Binding Voltage}"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock FontStyle="Italic" FontSize="11" Foreground="Gray" TextWrapping="Wrap"
                           Text="Nested static rings inherit their parent winding's voltage."/>
            </StackPanel>
        </DataTemplate>
    </Window.DataTemplates>

    <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="280,*">
        <Menu Grid.Row="0" Grid.ColumnSpan="2">
            <MenuItem Header="_File">
                <MenuItem Header="_Transformers"
                          ItemsSource="{Binding Examples}">
                    <MenuItem.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                    </MenuItem.ItemTemplate>
                    <MenuItem.ItemContainerTheme>
                        <ControlTheme TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                            <Setter Property="Command"
                                    Value="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SelectTransformerCommand}"/>
                            <Setter Property="CommandParameter" Value="{Binding}"/>
                        </ControlTheme>
                    </MenuItem.ItemContainerTheme>
                </MenuItem>
                <Separator/>
                <MenuItem Header="E_xit"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="Add _Winding" Command="{Binding AddWindingCommand}"/>
                <MenuItem Header="Add _Pressboard" Command="{Binding AddPressboardCommand}"/>
                <MenuItem Header="Add _Angle Ring" Command="{Binding AddAngleRingCommand}"/>
                <MenuItem Header="Add _Static Ring" Command="{Binding AddStaticRingCommand}"/>
                <MenuItem Header="Add Sc_enario" Command="{Binding AddScenarioCommand}"/>
                <MenuItem Header="Add _Cut" Command="{Binding AddCutCommand}"/>
                <Separator/>
                <MenuItem Header="_Remove Selected" Command="{Binding RemoveSelectedCommand}"/>
            </MenuItem>
            <MenuItem Header="_Run">
                <MenuItem Header="Solve _Cut" Command="{Binding SolveCutCommand}"/>
                <MenuItem Header="Solve _All Cuts" Command="{Binding SolveAllCutsCommand}"/>
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1" Grid.Column="0" Margin="8" RowDefinitions="Auto,2*,Auto,3*,Auto">
            <TextBlock Grid.Row="0" Text="Case" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TreeView Grid.Row="1"
                      ItemsSource="{Binding CaseTree}"
                      SelectedItem="{Binding SelectedTreeNode, Mode=TwoWay}">
                <TreeView.Styles>
                    <!-- Bind each container's expansion to the node so it survives rebuilds. -->
                    <Style Selector="TreeViewItem" x:DataType="vm:CaseTreeNode">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                    </Style>
                </TreeView.Styles>
                <TreeView.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}"
                                      x:DataType="vm:CaseTreeNode">
                        <TextBlock Text="{Binding Name}"/>
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>

            <GridSplitter Grid.Row="2" Height="4" HorizontalAlignment="Stretch"
                          Background="Transparent"/>

            <Border Grid.Row="3" BorderBrush="Gray" BorderThickness="1" Padding="8">
                <ScrollViewer>
                    <ContentControl Content="{Binding SelectedComponent}"/>
                </ScrollViewer>
            </Border>

            <ProgressBar Grid.Row="4" IsIndeterminate="True"
                         IsVisible="{Binding IsSolving}"
                         Height="6" Margin="0,6,0,0"/>
        </Grid>

        <Border Grid.Row="1" Grid.Column="1" Margin="8"
                BorderBrush="Gray" BorderThickness="1">
            <TabControl>
                <TabItem Header="Geometry">
                    <views:GeometryView Geometry="{Binding CurrentGeometry}"
                                        HighlightedSurfaces="{Binding HighlightedSurfaces}"/>
                </TabItem>
                <TabItem Header="Results">
                    <Grid RowDefinitions="Auto,*">
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12"
                                    Margin="6,4">
                            <TextBlock Text="Scenario:" VerticalAlignment="Center"/>
                            <ComboBox ItemsSource="{Binding ScenarioResults}"
                                      SelectedItem="{Binding SelectedScenarioResult, Mode=TwoWay}"
                                      MinWidth="160">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ScenarioResult">
                                        <TextBlock Text="{Binding DisplayName}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Text="Field:" VerticalAlignment="Center"/>
                            <ComboBox ItemsSource="{Binding AvailableFields}"
                                      SelectedItem="{Binding SelectedField, Mode=TwoWay}"
                                      MinWidth="80"/>
                            <CheckBox Content="Show mesh"
                                      IsChecked="{Binding ShowResultsMesh, Mode=TwoWay}"/>
                            <CheckBox Content="Show outlines"
                                      IsChecked="{Binding ShowResultsOutlines, Mode=TwoWay}"/>
                            <CheckBox Content="Show streamlines"
                                      IsChecked="{Binding ShowStreamlines, Mode=TwoWay}"/>
                        </StackPanel>
                        <views:ResultsView Grid.Row="1"
                                           Solution="{Binding CurrentSolution}"
                                           FieldName="{Binding SelectedField}"
                                           ShowMesh="{Binding ShowResultsMesh}"
                                           Geometry="{Binding CurrentGeometry}"
                                           ShowGeometryOutlines="{Binding ShowResultsOutlines}"
                                           Streamlines="{Binding Streamlines}"
                                           ShowStreamlines="{Binding ShowStreamlines}"/>
                    </Grid>
                </TabItem>
                <TabItem Header="Streamline Stress">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Grid.Row="0" Margin="6,4"
                                   Text="Per-streamline cumulative-method stress summary (worst margin first). E_avg/E_design are the governing cumulative average stress and distance-dependent withstand. Fields in kV/mm, lengths in mm."
                                   TextWrapping="Wrap"/>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding StreamlineSummary}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserSortColumns="False"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="#" Width="50">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="vm:StreamlineSummaryRow">
                                            <TextBlock Text="{Binding Name}" Margin="6,2" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="E_avg" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="vm:StreamlineSummaryRow">
                                            <TextBlock Text="{Binding PeakField, StringFormat='{}{0:N1}'}" Margin="6,2" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="E_design" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="vm:StreamlineSummaryRow">
                                            <TextBlock Text="{Binding AllowableField, StringFormat='{}{0:N1}'}" Margin="6,2" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Margin" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="vm:StreamlineSummaryRow">
                                            <TextBlock Text="{Binding MarginText}" Margin="6,2" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Max |E|" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="vm:StreamlineSummaryRow">
                                            <TextBlock Text="{Binding MaxField, StringFormat='{}{0:N1}'}" Margin="6,2" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Drop (kV)" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="vm:StreamlineSummaryRow">
                                            <TextBlock Text="{Binding TotalDrop, StringFormat='{}{0:N1}'}" Margin="6,2" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Length" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="vm:StreamlineSummaryRow">
                                            <TextBlock Text="{Binding Length, StringFormat='{}{0:N1}'}" Margin="6,2" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Segs" Width="60">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="vm:StreamlineSummaryRow">
                                            <TextBlock Text="{Binding SegmentCount}" Margin="6,2" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Peak (x,y)" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="vm:StreamlineSummaryRow">
                                            <TextBlock Text="{Binding PeakLocation}" Margin="6,2" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Termination" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="vm:StreamlineSummaryRow">
                                            <TextBlock Text="{Binding Termination}" Margin="6,2" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
                <TabItem Header="Scenario Envelope">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Grid.Row="0" Margin="6,4"
                                   Text="Worst-case envelope across all solved voltage permutations. The governing (lowest-margin) scenario is highlighted. Select a scenario above to view its field plot and per-streamline stress."
                                   TextWrapping="Wrap"/>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding ScenarioResults}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserSortColumns="False"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Scenario" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="vm:ScenarioResult">
                                            <TextBlock Text="{Binding DisplayName}" Margin="6,2" VerticalAlignment="Center"
                                                       FontWeight="{Binding IsGoverning, Converter={x:Static vm:BoolToWeightConverter.Instance}}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Margin" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="vm:ScenarioResult">
                                            <TextBlock Text="{Binding MarginText}" Margin="6,2" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Max |E|" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="vm:ScenarioResult">
                                            <TextBlock Text="{Binding MaxField, StringFormat='{}{0:N1}'}" Margin="6,2" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Lines" Width="70">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="vm:ScenarioResult">
                                            <TextBlock Text="{Binding StreamlineCount}" Margin="6,2" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Governing line" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="vm:ScenarioResult">
                                            <TextBlock Text="{Binding GoverningLocation}" Margin="6,2" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Worst?" Width="70">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="vm:ScenarioResult">
                                            <TextBlock Margin="6,2" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       Text="{Binding IsGoverning, Converter={x:Static vm:BoolToWorstConverter.Instance}}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>

        <TextBlock Grid.Row="2" Grid.ColumnSpan="2"
                   Margin="12,4"
                   Text="{Binding StatusMessage}"/>
    </Grid>

</Window>
